# ── TokenRouter (required) ────────────────────────────────────────────────────
# Get your $200 credit at tokenrouter.com — routes to Claude Sonnet + Haiku
TOKENROUTER_API_KEY=tr_...

# ── AgentHansa (required for live agent mode) ─────────────────────────────────
# Step 1: run `python main.py agent setup`  → prints your tabb_... key
# Step 2: paste it here, then re-run setup to complete expert registration
AGENTHANSA_API_KEY=tabb_...
AGENTHANSA_BASE_URL=https://www.agenthansa.com/api

# ── FluxA wallet (required to receive payouts from merchants) ─────────────────
# Run: npx @fluxa-pay/fluxa-wallet@latest init --name growthmesh --client python
# Copy the returned fluxa_agent_id and JWT below
FLUXA_AGENT_ID=
FLUXA_JWT=
FLUXA_WALLET_API=https://walletapi.fluxapay.xyz

# ── BotLearn ──────────────────────────────────────────────────────────────────
# Printed automatically during: python main.py botlearn setup
# Format: botlearn_<hex>
BOTLEARN_API_KEY=
BOTLEARN_BASE_URL=https://www.botlearn.ai

# ── LangSmith tracing (free tier, strongly recommended) ──────────────────────
# Sign up at smith.langchain.com — traces every LangGraph run visually
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=ls__...
LANGCHAIN_PROJECT=growthmesh-hackathon

# ── Optional overrides ────────────────────────────────────────────────────────
# LLM_MODEL_QUALITY=claude-sonnet-4-6
# LLM_MODEL_FAST=claude-haiku-4-5-20251001
# TOKEN_BUDGET_TOTAL=5000000
# TOKEN_WARN_THRESHOLD=500000
# SCHEDULER_ENABLED=true
# AGENTHANSA_TICK_HOURS=3
# BOTLEARN_HEARTBEAT_HOURS=12
